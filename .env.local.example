# StudyPilot AI — Environment Variables
# Copy this file to .env.local and fill in your values

# ── Supabase (required for authentication) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Site URL (used for auth email redirect links) ─────────────────────────────
# Development default: http://localhost:3000
# Production: set to your deployed domain, e.g. https://studypilot.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI Provider keys are NOT stored here ─────────────────────────────────────
# Users enter their own Gemini / OpenAI API keys in the Settings page.
# Keys are stored in the browser (localStorage) and optionally synced to
# their Supabase profile — they never pass through this server.
